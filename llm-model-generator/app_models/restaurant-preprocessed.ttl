### --- Option-A restructuring: cancel end events, completed chains, final validation ---

# General subprocess: cancel terminus + completed chain (confirmation -> notification -> end).
:end_event_cancelled_general rdf:type owl:NamedIndividual , bbo:EndEvent ;
    rdfs:comment "General restaurant data insertion cancelled" ;
    bbo:has_container :insert_general_restaurant_data .

:flow_1_7 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_general_restaurant_data ;
    bbo:has_sourceRef :inserted_data_confirmation_general_data ;
    bbo:has_targetRef :user_gets_notification_general_data .

:flow_1_8 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_general_restaurant_data ;
    bbo:has_sourceRef :user_gets_notification_general_data ;
    bbo:has_targetRef :end_event_data_insertion_completed_general_restaurant_data .

:flow_1_cancel rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_general_restaurant_data ;
    bbo:has_sourceRef :abort_general_data_insert_task ;
    bbo:has_targetRef :end_event_cancelled_general .

# Menus subprocess: cancel terminus (notification -> end was re-pointed on flow_2_8).
:end_event_cancelled_menus rdf:type owl:NamedIndividual , bbo:EndEvent ;
    rdfs:comment "Restaurant menus insertion cancelled" ;
    bbo:has_container :insert_restaurant_menus .

:flow_2_cancel rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_restaurant_menus ;
    bbo:has_sourceRef :abort_data_insert_task_restaurant_menus ;
    bbo:has_targetRef :end_event_cancelled_menus .

# Single final validation over the whole knowledge graph, after ingredients.
:final_shacl_validation rdf:type owl:NamedIndividual , bbo:ScriptTask ;
    rdfs:comment "Validate the whole stored knowledge graph using SHACL shapes" ;
    bbo:has_container :populate_restaurant_knowledge_graph ;
    obop:executesAction :final_validation_action .

:final_validation_action rdf:type owl:NamedIndividual , obop:SHACLValidation ;
    obop:hasInitiator "onClick" , "onEnter" ;
    rdfs:comment "Validate stored data in the knowledge graph using the SHACL file" .

:user_receives_final_validation rdf:type owl:NamedIndividual , bbo:UserTask ;
    rdfs:comment "User receives the final SHACL validation results" ;
    bbo:has_container :populate_restaurant_knowledge_graph .

:flow_final_1 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :populate_restaurant_knowledge_graph ;
    bbo:has_sourceRef :final_shacl_validation ;
    bbo:has_targetRef :user_receives_final_validation .

:flow_final_2 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :populate_restaurant_knowledge_graph ;
    bbo:has_sourceRef :user_receives_final_validation ;
    bbo:has_targetRef :end_event_process .


### ============================================================
### Continue buttons — let the user advance past each notification screen.
### One shared "continue" action (type "other": the engine only needs the
### received action to unblock the notification UserTask; it does not run a
### script, since the next node is the subprocess end event).
### ============================================================
:continue_action rdf:type owl:NamedIndividual , obop:Action ;
    obop:hasInitiator "onClick" ;
    obop:hasLabel "Continue" ;
    rdfs:comment "Advance the workflow from a notification screen to the next step." .

:button_continue_general rdf:type owl:NamedIndividual , obop:Button ;
    obop:activatesAction :continue_action ;
    obop:belongsTo :general_data_notification_block ;
    obop:belongsToVisual :vertical_layout_2 ;
    obop:hasLabel "Continue" ;
    obop:hasPositionNumber "1"^^xsd:int .

:button_continue_menus rdf:type owl:NamedIndividual , obop:Button ;
    obop:activatesAction :continue_action ;
    obop:belongsTo :block_3 ;
    obop:belongsToVisual :menu_notification_layout ;
    obop:hasLabel "Continue" ;
    obop:hasPositionNumber "1"^^xsd:int .

:button_continue_dishes rdf:type owl:NamedIndividual , obop:Button ;
    obop:activatesAction :continue_action ;
    obop:belongsTo :dish_notification_block ;
    obop:belongsToVisual :dish_notification_layout ;
    obop:hasLabel "Continue" ;
    obop:hasPositionNumber "1"^^xsd:int .

:button_continue_ingredients rdf:type owl:NamedIndividual , obop:Button ;
    obop:activatesAction :continue_action ;
    obop:belongsTo :ingredient_notification_block ;
    obop:belongsToVisual :ingredient_notification_layout ;
    obop:hasLabel "Continue" ;
    obop:hasPositionNumber "1"^^xsd:int .
