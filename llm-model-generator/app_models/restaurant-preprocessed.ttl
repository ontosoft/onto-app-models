:flow_2_5_2 rdf:type owl:NamedIndividual , bbo:ConditionalSequenceFlow ;
    bbo:has_container :insert_restaurant_menus ;
    bbo:has_sourceRef :DecisionGateway_2_1 ;
    bbo:has_targetRef :save_data_insert_restaurant_menus ;
