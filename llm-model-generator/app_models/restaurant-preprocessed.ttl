    bbo:ScriptTask ;
    rdfs:comment "Processing received data" ;
    bbo:has_container :insert_restaurant_menus .

# 4. Save Data (uses :action_1, the Save/Submit action from KG2)
:save_data_insert_restaurant_menus rdf:type owl:NamedIndividual ,
    bbo:ScriptTask ;
    rdfs:comment "Save the entered data in the rdfstore" ;
