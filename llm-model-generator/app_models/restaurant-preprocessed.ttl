### ============================================================
### Menus data layer — makes the insert_restaurant_menus form generate.
### Mirrors the general-data subprocess (block + SHACL shape + fields +
### buttons + layouts + notification). Menu data model: menuName, menuType.
### ============================================================

:Menu rdf:type owl:Class ;
    rdfs:label "Menu" .

:menuName rdf:type owl:DatatypeProperty ;
    rdfs:label "Menu name" .
:menuType rdf:type owl:DatatypeProperty ;
    rdfs:label "Menu type" .

### Form block for entering a menu
:menu_block rdf:type owl:NamedIndividual , obop:Block ;
    obop:hasPositionNumber "0"^^xsd:int ;
    rdfs:label "Restaurant menu data"^^rdf:PlainLiteral ;
    obop:targetClass :Menu .

:menu_vertical_layout rdf:type owl:NamedIndividual , obop:VerticalLayout ;
    dc:title "Main vertical layout for the menu form"^^rdf:PlainLiteral ;
    obop:belongsTo :menu_block ;
    obop:hasPositionNumber "0"^^xsd:int .

:menu_horizontal_layout rdf:type owl:NamedIndividual , obop:HorizontalLayout ;
    dc:title "Horizontal layout for submit and cancel buttons."^^rdf:PlainLiteral ;
    obop:belongsToVisual :menu_vertical_layout ;
    obop:hasPositionNumber "4"^^xsd:int .

### Fields
:field_menu_name rdf:type owl:NamedIndividual , obop:Field ;
    rdfs:label "Menu name"^^rdf:PlainLiteral ;
    obop:belongsTo :menu_block ;
    obop:belongsToVisual :menu_vertical_layout ;
    obop:containsDatatype :menuName ;
    obop:isRelatedToTargetOntologyInstance :menuShape ;
    obop:hasLabel "Menu name" ;
    obop:hasPositionNumber "0"^^xsd:int .

:field_menu_type rdf:type owl:NamedIndividual , obop:Field ;
    rdfs:label "Menu type"^^rdf:PlainLiteral ;
    obop:belongsTo :menu_block ;
    obop:belongsToVisual :menu_vertical_layout ;
    obop:containsDatatype :menuType ;
    obop:isRelatedToTargetOntologyInstance :menuShape ;
    obop:hasLabel "Menu type" ;
    obop:hasPositionNumber "1"^^xsd:int .

### Submit / Cancel actions for the menu block
:submit_action_restaurant_menu rdf:type owl:NamedIndividual , obop:SubmitBlockAction ;
    obop:actionInBlock :menu_block ;
    obop:hasInitiator "onClick" , "onEnter" ;
    obop:hasLabel "Submit" ;
    rdfs:comment "Save the entered menu data in the knowledge graph" .

:abort_action_restaurant_menu rdf:type owl:NamedIndividual , obop:CancelBlockAction ;
    obop:actionInBlock :menu_block ;
    obop:hasInitiator "onClick" ;
    obop:hasLabel "Cancel" ;
    rdfs:comment "Cancel the menu data entry" .

### Buttons
:button_menu_submit rdf:type owl:NamedIndividual , obop:Button ;
    obop:activatesAction :submit_action_restaurant_menu ;
    obop:belongsTo :menu_block ;
    obop:belongsToVisual :menu_horizontal_layout ;
    obop:hasLabel "Submit" ;
    obop:hasPositionNumber "0"^^xsd:int .

:button_menu_cancel rdf:type owl:NamedIndividual , obop:Button ;
    obop:activatesAction :abort_action_restaurant_menu ;
    obop:belongsTo :menu_block ;
    obop:belongsToVisual :menu_horizontal_layout ;
    obop:hasLabel "Cancel" ;
    obop:hasPositionNumber "1"^^xsd:int .

### SHACL shape for the menu form (modelBelongsTo links it to :menu_block)
:menuShape rdf:type owl:NamedIndividual , shacl:NodeShape ;
    obop:modelBelongsTo :menu_block ;
    shacl:targetClass :Menu ;
    shacl:property [
        shacl:path :menuName ;
        shacl:datatype xsd:string ;
        shacl:maxCount 1 ;
        shacl:name "Menu name" ;
        shacl:order 0 ;
        dash:singleLine "true"^^xsd:boolean ;
        obop:specifedBy :field_menu_name
    ] , [
        shacl:path :menuType ;
        shacl:datatype xsd:string ;
        shacl:maxCount 1 ;
        shacl:name "Menu type" ;
        shacl:order 1 ;
        dash:singleLine "true"^^xsd:boolean ;
        obop:specifedBy :field_menu_type
    ] .

### Menus notification block (block_3, used by generateJSONFormForNotification_confirm_menus)
:block_3 rdf:type owl:NamedIndividual , obop:Block ;
    rdfs:label "Restaurant menu saved - Notification"^^rdf:PlainLiteral ;
    obop:hasPositionNumber "0"^^xsd:int .

:menu_notification_layout rdf:type owl:NamedIndividual , obop:VerticalLayout ;
    rdfs:label "Main vertical layout for the menu notification"^^rdf:PlainLiteral ;
    obop:belongsTo :block_3 ;
    obop:hasPositionNumber "0"^^xsd:int .

:menu_notification_label rdf:type owl:NamedIndividual , obop:Label ;
    obop:belongsTo :block_3 ;
    obop:belongsToVisual :menu_notification_layout ;
    obop:hasPositionNumber "0"^^xsd:int ;
    obop:hasText "The menu data have been stored in the database."^^rdf:PlainLiteral .


### ============================================================
### Dishes subprocess (insert_dishes_in_menus) — full BBO chain + data layer.
### Built in the Option-A shape: no per-subprocess SHACL validation; the cancel
### branch terminates at its own cancel end event. Entered via the main flow_3
### (menus -> dishes). Data model: dishName, price, description.
### ============================================================

### --- BBO control flow ---
:start_insert_dishes rdf:type owl:NamedIndividual , bbo:SubProcessStartEvent ;
    rdfs:comment "The start of inserting dishes for a menu." ;
    bbo:has_container :insert_dishes_in_menus .

:generate_form_representation_dishes rdf:type owl:NamedIndividual , bbo:ScriptTask ;
    rdfs:comment "Generate the form representation for :dish_block on the server side" ;
    bbo:has_container :insert_dishes_in_menus ;
    obop:executesAction :generateJSONFormAction_dishes .

:generateJSONFormAction_dishes rdf:type owl:NamedIndividual , obop:GenerateJSONForm ;
    obop:actionInBlock :dish_block .

:user_enters_data_dishes rdf:type owl:NamedIndividual , bbo:UserTask ;
    rdfs:comment "User entering dish data in the web form" ;
    bbo:has_container :insert_dishes_in_menus .

:processing_received_data_dishes rdf:type owl:NamedIndividual , bbo:ScriptTask ;
    rdfs:comment "Processing received dish data" ;
    bbo:has_container :insert_dishes_in_menus .

:DecisionGateway_dishes rdf:type owl:NamedIndividual , bbo:ExclusiveGateway ;
    rdfs:label "Decision on the entered dish data (Submit or Cancel)" ;
    bbo:has_container :insert_dishes_in_menus .

:save_data_insert_dishes rdf:type owl:NamedIndividual , bbo:ScriptTask ;
    rdfs:comment "Save the entered dish data in the knowledge graph" ;
    obop:executesAction :submit_action_dishes ;
    bbo:has_container :insert_dishes_in_menus .

:abort_data_insert_task_dishes rdf:type owl:NamedIndividual , bbo:ScriptTask ;
    rdfs:comment "Dish data insertion aborted (Executed by Cancel Action)" ;
    obop:executesAction :abort_action_dishes ;
    bbo:has_container :insert_dishes_in_menus .

:inserted_data_confirmation_dishes rdf:type owl:NamedIndividual , bbo:ScriptTask ;
    rdfs:comment "Generate the notification that dish data has been stored" ;
    bbo:has_container :insert_dishes_in_menus ;
    obop:executesAction :generateJSONFormForNotification_confirm_dishes .

:generateJSONFormForNotification_confirm_dishes rdf:type owl:NamedIndividual , obop:GenerateJSONForm ;
    obop:actionInBlock :dish_notification_block .

:user_gets_notification_dishes rdf:type owl:NamedIndividual , bbo:UserTask ;
    rdfs:comment "User views the dish data saved notification" ;
    bbo:has_container :insert_dishes_in_menus .

:end_event_data_insertion_completed_dishes rdf:type owl:NamedIndividual , bbo:EndEvent ;
    rdfs:comment "Completed the dish data insertion." ;
    bbo:has_container :insert_dishes_in_menus .

:end_event_cancelled_dishes rdf:type owl:NamedIndividual , bbo:EndEvent ;
    rdfs:comment "Dish data insertion cancelled" ;
    bbo:has_container :insert_dishes_in_menus .

### Condition expressions (gateway routing)
:cancel_condition_expression_dishes rdf:type owl:NamedIndividual , bbo:ConditionExpression ;
    obop:selectedAction :abort_action_dishes ;
    rdfs:comment "Condition expression for the dish Cancel action." .

:submit_condition_expression_dishes rdf:type owl:NamedIndividual , bbo:ConditionExpression ;
    obop:selectedAction :submit_action_dishes ;
    rdfs:comment "Condition expression for the dish Submit action." .

### Sequence flows
:flow_d1 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dishes_in_menus ;
    bbo:has_sourceRef :start_insert_dishes ;
    bbo:has_targetRef :generate_form_representation_dishes .

:flow_d2 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dishes_in_menus ;
    bbo:has_sourceRef :generate_form_representation_dishes ;
    bbo:has_targetRef :user_enters_data_dishes .

:flow_d3 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dishes_in_menus ;
    bbo:has_sourceRef :user_enters_data_dishes ;
    bbo:has_targetRef :processing_received_data_dishes .

:flow_d4 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dishes_in_menus ;
    bbo:has_sourceRef :processing_received_data_dishes ;
    bbo:has_targetRef :DecisionGateway_dishes .

:flow_d5_1 rdf:type owl:NamedIndividual , bbo:ConditionalSequenceFlow ;
    bbo:has_container :insert_dishes_in_menus ;
    bbo:has_sourceRef :DecisionGateway_dishes ;
    bbo:has_targetRef :abort_data_insert_task_dishes ;
    bbo:has_conditionExpression :cancel_condition_expression_dishes .

:flow_d5_2 rdf:type owl:NamedIndividual , bbo:ConditionalSequenceFlow ;
    bbo:has_container :insert_dishes_in_menus ;
    bbo:has_sourceRef :DecisionGateway_dishes ;
    bbo:has_targetRef :save_data_insert_dishes ;
    bbo:has_conditionExpression :submit_condition_expression_dishes .

:flow_d6 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dishes_in_menus ;
    bbo:has_sourceRef :save_data_insert_dishes ;
    bbo:has_targetRef :inserted_data_confirmation_dishes .

:flow_d7 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dishes_in_menus ;
    bbo:has_sourceRef :inserted_data_confirmation_dishes ;
    bbo:has_targetRef :user_gets_notification_dishes .

:flow_d8 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dishes_in_menus ;
    bbo:has_sourceRef :user_gets_notification_dishes ;
    bbo:has_targetRef :end_event_data_insertion_completed_dishes .

:flow_d_cancel rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dishes_in_menus ;
    bbo:has_sourceRef :abort_data_insert_task_dishes ;
    bbo:has_targetRef :end_event_cancelled_dishes .

### --- Data layer ---
:Dish rdf:type owl:Class ; rdfs:label "Dish" .
:dishName rdf:type owl:DatatypeProperty ; rdfs:label "Dish name" .
:price rdf:type owl:DatatypeProperty ; rdfs:label "Price" .
:description rdf:type owl:DatatypeProperty ; rdfs:label "Description" .

:dish_block rdf:type owl:NamedIndividual , obop:Block ;
    obop:hasPositionNumber "0"^^xsd:int ;
    rdfs:label "Dish data"^^rdf:PlainLiteral ;
    obop:targetClass :Dish .

:dish_vertical_layout rdf:type owl:NamedIndividual , obop:VerticalLayout ;
    dc:title "Main vertical layout for the dish form"^^rdf:PlainLiteral ;
    obop:belongsTo :dish_block ;
    obop:hasPositionNumber "0"^^xsd:int .

:dish_horizontal_layout rdf:type owl:NamedIndividual , obop:HorizontalLayout ;
    dc:title "Horizontal layout for submit and cancel buttons."^^rdf:PlainLiteral ;
    obop:belongsToVisual :dish_vertical_layout ;
    obop:hasPositionNumber "4"^^xsd:int .

:field_dish_name rdf:type owl:NamedIndividual , obop:Field ;
    rdfs:label "Dish name"^^rdf:PlainLiteral ;
    obop:belongsTo :dish_block ;
    obop:belongsToVisual :dish_vertical_layout ;
    obop:containsDatatype :dishName ;
    obop:isRelatedToTargetOntologyInstance :dishShape ;
    obop:hasLabel "Dish name" ;
    obop:hasPositionNumber "0"^^xsd:int .

:field_dish_price rdf:type owl:NamedIndividual , obop:Field ;
    rdfs:label "Price"^^rdf:PlainLiteral ;
    obop:belongsTo :dish_block ;
    obop:belongsToVisual :dish_vertical_layout ;
    obop:containsDatatype :price ;
    obop:isRelatedToTargetOntologyInstance :dishShape ;
    obop:hasLabel "Price" ;
    obop:hasPositionNumber "1"^^xsd:int .

:field_dish_description rdf:type owl:NamedIndividual , obop:Field ;
    rdfs:label "Description"^^rdf:PlainLiteral ;
    obop:belongsTo :dish_block ;
    obop:belongsToVisual :dish_vertical_layout ;
    obop:containsDatatype :description ;
    obop:isRelatedToTargetOntologyInstance :dishShape ;
    obop:hasLabel "Description" ;
    obop:hasPositionNumber "2"^^xsd:int .

:submit_action_dishes rdf:type owl:NamedIndividual , obop:SubmitBlockAction ;
    obop:actionInBlock :dish_block ;
    obop:hasInitiator "onClick" , "onEnter" ;
    obop:hasLabel "Submit" ;
    rdfs:comment "Save the entered dish data in the knowledge graph" .

:abort_action_dishes rdf:type owl:NamedIndividual , obop:CancelBlockAction ;
    obop:actionInBlock :dish_block ;
    obop:hasInitiator "onClick" ;
    obop:hasLabel "Cancel" ;
    rdfs:comment "Cancel the dish data entry" .

:button_dish_submit rdf:type owl:NamedIndividual , obop:Button ;
    obop:activatesAction :submit_action_dishes ;
    obop:belongsTo :dish_block ;
    obop:belongsToVisual :dish_horizontal_layout ;
    obop:hasLabel "Submit" ;
    obop:hasPositionNumber "0"^^xsd:int .

:button_dish_cancel rdf:type owl:NamedIndividual , obop:Button ;
    obop:activatesAction :abort_action_dishes ;
    obop:belongsTo :dish_block ;
    obop:belongsToVisual :dish_horizontal_layout ;
    obop:hasLabel "Cancel" ;
    obop:hasPositionNumber "1"^^xsd:int .

:dishShape rdf:type owl:NamedIndividual , shacl:NodeShape ;
    obop:modelBelongsTo :dish_block ;
    shacl:targetClass :Dish ;
    shacl:property [
        shacl:path :dishName ;
        shacl:datatype xsd:string ;
        shacl:maxCount 1 ;
        shacl:name "Dish name" ;
        shacl:order 0 ;
        dash:singleLine "true"^^xsd:boolean ;
        obop:specifedBy :field_dish_name
    ] , [
        shacl:path :price ;
        shacl:datatype xsd:decimal ;
        shacl:maxCount 1 ;
        shacl:name "Price" ;
        shacl:order 1 ;
        dash:singleLine "true"^^xsd:boolean ;
        obop:specifedBy :field_dish_price
    ] , [
        shacl:path :description ;
        shacl:datatype xsd:string ;
        shacl:maxCount 1 ;
        shacl:name "Description" ;
        shacl:order 2 ;
        obop:specifedBy :field_dish_description
    ] .

:dish_notification_block rdf:type owl:NamedIndividual , obop:Block ;
    rdfs:label "Dish saved - Notification"^^rdf:PlainLiteral ;
    obop:hasPositionNumber "0"^^xsd:int .

:dish_notification_layout rdf:type owl:NamedIndividual , obop:VerticalLayout ;
    rdfs:label "Main vertical layout for the dish notification"^^rdf:PlainLiteral ;
    obop:belongsTo :dish_notification_block ;
    obop:hasPositionNumber "0"^^xsd:int .

:dish_notification_label rdf:type owl:NamedIndividual , obop:Label ;
    obop:belongsTo :dish_notification_block ;
    obop:belongsToVisual :dish_notification_layout ;
    obop:hasPositionNumber "0"^^xsd:int ;
    obop:hasText "The dish data have been stored in the database."^^rdf:PlainLiteral .


### ============================================================
### Ingredients subprocess (insert_dish_ingredients) — full BBO chain + data
### layer. Clean Option-A shape (no per-subprocess validation; cancel -> own
### cancel end event). Entered via the main flow_4 (dishes -> ingredients).
### Data model: ingredientName.
