    bbo:has_container :insert_dish_ingredients .

:save_data_insert_ingredients rdf:type owl:NamedIndividual , bbo:ScriptTask ;
    rdfs:comment "Save the entered ingredient data in the knowledge graph" ;
    obop:executesAction :submit_action_ingredients ;
    bbo:has_container :insert_dish_ingredients .

:abort_data_insert_task_ingredients rdf:type owl:NamedIndividual , bbo:ScriptTask ;
    rdfs:comment "Ingredient data insertion aborted (Executed by Cancel Action)" ;
    obop:executesAction :abort_action_ingredients ;
    bbo:has_container :insert_dish_ingredients .

:inserted_data_confirmation_ingredients rdf:type owl:NamedIndividual , bbo:ScriptTask ;
    rdfs:comment "Generate the notification that ingredient data has been stored" ;
    bbo:has_container :insert_dish_ingredients ;
    obop:executesAction :generateJSONFormForNotification_confirm_ingredients .

:generateJSONFormForNotification_confirm_ingredients rdf:type owl:NamedIndividual , obop:GenerateJSONForm ;
