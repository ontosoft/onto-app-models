:flow_2_7 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ; 
    bbo:has_container :insert_restaurant_menus ;
    bbo:has_sourceRef :inserted_data_confirmation_restaurant_menus ; 
    bbo:has_targetRef :user_gets_notification_restaurant_menus .

:flow_2_8 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ; 
    bbo:has_container :insert_restaurant_menus ; 
