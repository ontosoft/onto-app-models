    bbo:has_container :insert_dish_ingredients .

### Condition expressions (gateway routing)
:cancel_condition_expression_ingredients rdf:type owl:NamedIndividual , bbo:ConditionExpression ;
    obop:selectedAction :abort_action_ingredients ;
    rdfs:comment "Condition expression for the ingredient Cancel action." .

:submit_condition_expression_ingredients rdf:type owl:NamedIndividual , bbo:ConditionExpression ;
    obop:selectedAction :submit_action_ingredients ;
    rdfs:comment "Condition expression for the ingredient Submit action." .

### Sequence flows
:flow_i1 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dish_ingredients ;
    bbo:has_sourceRef :start_insert_ingredients ;
    bbo:has_targetRef :generate_form_representation_ingredients .

:flow_i2 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dish_ingredients ;
    bbo:has_sourceRef :generate_form_representation_ingredients ;
    bbo:has_targetRef :user_enters_data_ingredients .

:flow_i3 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dish_ingredients ;
    bbo:has_sourceRef :user_enters_data_ingredients ;
    bbo:has_targetRef :processing_received_data_ingredients .

:flow_i4 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dish_ingredients ;
    bbo:has_sourceRef :processing_received_data_ingredients ;
    bbo:has_targetRef :DecisionGateway_ingredients .

:flow_i5_1 rdf:type owl:NamedIndividual , bbo:ConditionalSequenceFlow ;
    bbo:has_container :insert_dish_ingredients ;
    bbo:has_sourceRef :DecisionGateway_ingredients ;
    bbo:has_targetRef :abort_data_insert_task_ingredients ;
    bbo:has_conditionExpression :cancel_condition_expression_ingredients .

:flow_i5_2 rdf:type owl:NamedIndividual , bbo:ConditionalSequenceFlow ;
    bbo:has_container :insert_dish_ingredients ;
    bbo:has_sourceRef :DecisionGateway_ingredients ;
    bbo:has_targetRef :save_data_insert_ingredients ;
    bbo:has_conditionExpression :submit_condition_expression_ingredients .

:flow_i6 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dish_ingredients ;
    bbo:has_sourceRef :save_data_insert_ingredients ;
    bbo:has_targetRef :inserted_data_confirmation_ingredients .

:flow_i7 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dish_ingredients ;
    bbo:has_sourceRef :inserted_data_confirmation_ingredients ;
    bbo:has_targetRef :user_gets_notification_ingredients .

:flow_i8 rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dish_ingredients ;
    bbo:has_sourceRef :user_gets_notification_ingredients ;
    bbo:has_targetRef :end_event_data_insertion_completed_ingredients .

:flow_i_cancel rdf:type owl:NamedIndividual , bbo:NormalSequenceFlow ;
    bbo:has_container :insert_dish_ingredients ;
    bbo:has_sourceRef :abort_data_insert_task_ingredients ;
    bbo:has_targetRef :end_event_cancelled_ingredients .

### --- Data layer ---
:Ingredient rdf:type owl:Class ; rdfs:label "Ingredient" .
:ingredientName rdf:type owl:DatatypeProperty ; rdfs:label "Ingredient name" .

