  <rdfs:range rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#OutputSet"/>
  <rdfs:comment xml:lang="en">A reference to the OutputSets defined by the InputOutputSpecification. Every InputOutputSpecification MUST define at least one OutputSet.</rdfs:comment>
  <rdfs:label xml:lang="en">has_outputSet</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_parameter">
