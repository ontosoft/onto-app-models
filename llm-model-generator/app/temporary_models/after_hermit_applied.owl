</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_property">
  <owl:inverseOf rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_propertyElement"/>
  <rdfs:domain>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Activity"/>
        <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Event"/>
        <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Process"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:domain>
  <rdfs:range rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Property"/>
  <rdfs:comment xml:lang="en">Modeler-defined properties MAY be added to a Process. These properties are contained within the Process. All Tasks and Sub-Processes SHALL have access to these properties.</rdfs:comment>
  <rdfs:label xml:lang="en">has_property</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_propertyElement">
  <rdfs:domain rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Property"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Activity"/>
        <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Event"/>
        <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Process"/>
      </owl:unionOf>
    </owl:Class>
  </rdfs:range>
</owl:ObjectProperty>

