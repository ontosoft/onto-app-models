  </rdfs:domain>
  <rdfs:range rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Rendering"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_renderingTask">
  <rdfs:domain rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Rendering"/>
  <rdfs:range>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#GlobalUserTask"/>
