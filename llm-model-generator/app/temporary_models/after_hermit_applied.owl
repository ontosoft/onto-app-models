<owl:Class rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#IntermediateEvent">
  <owl:equivalentClass>
    <owl:Class>
      <owl:unionOf rdf:parseType="Collection">
        <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#BoundaryEvent"/>
        <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#IntermediateCatchEvent"/>
        <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#IntermediateThrowEvent"/>
      </owl:unionOf>
    </owl:Class>
  </owl:equivalentClass>
  <rdfs:subClassOf rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Event"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_outgoing"/>
      <owl:someValuesFrom rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#SequenceFlow"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Intermediate Event indicates where something happens (an Event) somewhere between the start and end of a Process. It will affect the flow of the Process, but will not start or (directly) terminate the process.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">IntermediateEvent</rdfs:label>
</owl:Class>

<owl:Class rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#InterruptingBoundaryEvent">
  <rdfs:subClassOf rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#BoundaryEvent"/>
  <owl:disjointWith rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#LinkEvent"/>
  <owl:disjointWith rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#NoneEvent"/>
  <owl:disjointWith rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#TerminateEvent"/>
  <rdfs:comment xml:lang="en">the Activity attached to this event should be cancelled</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#ManualTask">
  <rdfs:subClassOf rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Task"/>
  <rdfs:comment xml:lang="en">A Manual Task is a Task that is expected to be performed without the aid of any business process execution engine or any application. An example of this could be a telephone technician installing a telephone at a customer location.</rdfs:comment>
  <rdfs:label xml:lang="en">ManualTask</rdfs:label>
</owl:Class>

