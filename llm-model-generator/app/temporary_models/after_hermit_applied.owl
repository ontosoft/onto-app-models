  <rdfs:domain rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#InputOutputSpecification"/>
  <rdfs:range rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Resource"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_resourceParameterBindings">
  <rdfs:comment xml:lang="en">This defines the Parameter bindings used for the
Resource assignment (see below). Is only applicable if a
resourceRef is specified.</rdfs:comment>
  <rdfs:label xml:lang="en">has_resourceParameterBindings</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_resourceParameters">
