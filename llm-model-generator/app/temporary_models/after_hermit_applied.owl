    <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#ConsumableResource"/>
    <rdf:Description rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#DataResource"/>
