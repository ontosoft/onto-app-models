  <rdfs:domain rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#InputOutputSpecification"/>
  <rdfs:range rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#ParameterValueBinding"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_parameterValueBindingOutput">
  <rdfs:domain rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#InputOutputSpecification"/>
  <rdfs:range rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#ParameterValueBinding"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_part">
  <owl:inverseOf rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#is_partOf"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#is_partOf"/>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_prefix">
  <rdfs:domain rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#UnitOfMeasure"/>
  <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/UO_0000046"/>
  <rdfs:comment xml:lang="en">This relation allows to specifiy the prefix (centi, mili, etc.) of a given unit of measure.</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has_prefix</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_process">
  <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
  <rdfs:range rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Process"/>
  <rdfs:comment xml:lang="en">the process assigned to the resource role</rdfs:comment>
