  <rdfs:comment xml:lang="en">Reference to the parameter defined by the Resource.</rdfs:comment>
  <rdfs:label xml:lang="en">has_parameterRef</rdfs:label>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_parameterValue">
