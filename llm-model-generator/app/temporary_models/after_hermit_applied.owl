  <rdfs:subClassOf rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Parameter"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_unitOfMeasure"/>
      <owl:onClass rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#UnitOfMeasure"/>
      <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:comment xml:lang="en">parameters that have only quantitative values</rdfs:comment>
  <rdfs:label xml:lang="en">QuantitativeParameter</rdfs:label>
</owl:Class>

<owl:Class rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#WorkProduct">
  <rdfs:subClassOf rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Resource"/>
</owl:Class>

<owl:Class rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#SoftwareResource">
  <rdfs:subClassOf rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Agent"/>
  <rdfs:subClassOf rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Resource"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#is_installedOn"/>
      <owl:onClass rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Computer"/>
      <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:comment xml:lang="en">A software used by an agent to perform a process, or a software agent that executes specific tasks.</rdfs:comment>
  <rdfs:label xml:lang="en">SoftwareResource</rdfs:label>
</owl:Class>

<owl:Class rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Computer">
  <rdfs:subClassOf rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#MaterialResource"/>
  <rdfs:label xml:lang="en">Computer</rdfs:label>
</owl:Class>

<owl:Class rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Agent">
  <rdfs:comment xml:lang="en">Person or a Software that performs an activity</rdfs:comment>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Agent</rdfs:label>
</owl:Class>

<owl:Class rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Role">
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Role</rdfs:label>
</owl:Class>

<owl:Class rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#ManufacturingFacility">
