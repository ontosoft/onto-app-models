<owl:ObjectProperty rdf:about="https://www.irit.fr/recherches/MELODI/ontologies/BBO#has_supportedInterfaceRefs">
  <rdfs:domain rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#CallableElement"/>
  <rdfs:range rdf:resource="https://www.irit.fr/recherches/MELODI/ontologies/BBO#Interface"/>
  <rdfs:comment xml:lang="en">The Interfaces describing the external behavior provided by this element.</rdfs:comment>
