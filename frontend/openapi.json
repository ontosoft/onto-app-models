    "/api/v1/generator/load_inner_uimodel_from_server": {
      "get": {
        "tags": ["onto_model_generator"],
        "summary": "Load Inner Server Model",
        "description": "Load the chosen inner UI model from the server.\n\nArgs:\n    filename (str): The name of the UI model file to be loaded.\n    This file is stored in the 'app_models' folder as RDF file",
        "operationId": "onto_model_generator-load_inner_server_model",
        "parameters": [
          {
            "name": "filename",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "title": "Filename" }
          },
          {
            "name": "force_load",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [{ "type": "boolean" }, { "type": "null" }],
              "description": "Force reload the model",
              "title": "Force Load"
            },
            "description": "Force reload the model"
          }
        ],
        "responses": {
          "200": {
            "description": "Load the chosen app model on the server",
            "content": { "application/json": { "schema": {} } }
